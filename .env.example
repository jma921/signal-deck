# SignalDeck reads these values as first-run bootstrap defaults.
# After startup, local SQLite runtime settings and secrets are canonical.

# App
SIGNALDECK_MODE=simulation
SIGNALDECK_BIND_HOST=127.0.0.1
SIGNALDECK_DATA_DIR=
PORT=3000

# OBS as the first Encoder implementation
OBS_ENABLED=false
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=

# PCO Services owns the Service Order. SignalDeck owns Service Position.
PCO_ENABLED=false
PCO_BASE_URL=https://api.planningcenteronline.com
PCO_SERVICE_TYPE_ID=
PCO_PLAN_ID=
PCO_POLL_SECONDS=60
PCO_TOKEN=

# ProPresenter owns Current Slide and Next Slide.
PROPRESENTER_ENABLED=false
PROPRESENTER_HOST=127.0.0.1
PROPRESENTER_PORT=1025
